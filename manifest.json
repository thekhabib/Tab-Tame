{
  "manifest_version": 3,
  "name": "TabTame",
  "version": "1.0.7",
  "description": "All links open in the current tab — no tab clutter. Per-site rules, focus mode, tab search, idle close, and more.",
  "author": "Khabib Toshev",
  "homepage_url": "https://github.com/thekhabib/Tab-Tame",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    },
    "default_title": "TabTame",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["settings-preload.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "commands": {
    "toggle-extension": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Toggle TabTame on/off"
    },
    "search-tabs": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Search open tabs"
    },
    "switch-tab-1": { "description": "Switch to tab 1" },
    "switch-tab-2": { "description": "Switch to tab 2" },
    "switch-tab-3": { "description": "Switch to tab 3" },
    "switch-tab-4": { "description": "Switch to tab 4" },
    "switch-tab-5": { "description": "Switch to tab 5" },
    "switch-tab-6": { "description": "Switch to tab 6" },
    "switch-tab-7": { "description": "Switch to tab 7" },
    "switch-tab-8": { "description": "Switch to tab 8" },
    "switch-tab-9": { "description": "Switch to tab 9" }
  },

  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"]
}
